# LLM API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Persistent memory embeddings reuse existing model API keys.
# Priority: OpenAI (OPENAI_API_KEY) -> Gemini (GOOGLE_API_KEY) -> Ollama (OLLAMA_BASE_URL)
# No additional memory-specific API keys required.

# Stock Market API Key
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Korean stocks (DART 전자공시) — enables get_financials_kr
# Issue at https://opendart.fss.or.kr
DART_API_KEY=your-dart-api-key

# Korean 공매도 잔고 (short interest) — enables get_short_balance_kr.
# Requires a KRX Data Marketplace login (data.krx.co.kr); anonymous access is
# blocked. Either set a native ID/PW, OR (for social/Naver-login accounts that
# have no password) paste the Cookie header from a logged-in browser session
# into KRX_COOKIE. KRX_COOKIE takes precedence but cannot auto-refresh — re-paste
# when it expires.
KRX_ID=your-krx-id
KRX_PW=your-krx-password
# KRX_COOKIE=JSESSIONID=...; (copy from data.krx.co.kr DevTools after logging in)

# Korean 국민연금 (NPS) holdings — enables get_nps_holdings.
# Use the *Decoded* service key from https://www.data.go.kr (dataset 3070507).
DATA_GO_KR_SERVICE_KEY=your-data-go-kr-service-key

# Web Search API Keys (Exa → Perplexity → Tavily → LangSearch)
EXASEARCH_API_KEY=your-exa-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
TAVILY_API_KEY=your-tavily-api-key
LANGSEARCH_API_KEY=your-langsearch-api-key

# X/Twitter API (enables x_search tool for public sentiment research)
X_BEARER_TOKEN=your-X-bearer-token

# LangSmith 
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=false
